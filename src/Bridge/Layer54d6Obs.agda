layer54d6BdyView : Layer54d6BdyView
layer54d6BdyView .Layer54d6BdyView.dummy = 0

layer54d6BulkView : Layer54d6BulkView
layer54d6BulkView .Layer54d6BulkView.dummy = 0

Layer54d6Obs∂ : ObsPackage Layer54d6Region
Layer54d6Obs∂ .ObsPackage.obs = S-cut layer54d6BdyView

Layer54d6ObsBulk : ObsPackage Layer54d6Region
Layer54d6ObsBulk .ObsPackage.obs = L-min layer54d6BulkView

-- layer54d6-pointwise-rep — All 2 orbit cases by refl
-- S-cut-rep and L-min-rep return the same ℕ literal on each orbit.
--  Generated by sim/prototyping/13_generate_layerN.py --depth 6
--  Do not edit by hand.  Regenerate with:
--    python3 sim/prototyping/13_generate_layerN.py --depth 6

layer54d6-pointwise-rep :
  (o : Layer54d6OrbitRep) → S-cut-rep o ≡ L-min-rep o
layer54d6-pointwise-rep mc1 = refl
layer54d6-pointwise-rep mc2 = refl

-- layer54d6-pointwise — Lifted to all 720 regions
-- via classifyLayer54d6 (the orbit reduction 1-line lifting)
--  Generated by sim/prototyping/13_generate_layerN.py --depth 6
--  Do not edit by hand.  Regenerate with:
--    python3 sim/prototyping/13_generate_layerN.py --depth 6

layer54d6-pointwise :
  (r : Layer54d6Region) →
  S-cut layer54d6BdyView r ≡ L-min layer54d6BulkView r
layer54d6-pointwise r = layer54d6-pointwise-rep (classifyLayer54d6 r)

S∂Layer54d6 : Layer54d6Region → ℚ≥0
S∂Layer54d6 = S-cut layer54d6BdyView

LBLayer54d6 : Layer54d6Region → ℚ≥0
LBLayer54d6 = L-min layer54d6BulkView

layer54d6-obs-path : S∂Layer54d6 ≡ LBLayer54d6
layer54d6-obs-path = funExt layer54d6-pointwise

layer54d6-package-path : Layer54d6Obs∂ ≡ Layer54d6ObsBulk
layer54d6-package-path i .ObsPackage.obs = layer54d6-obs-path i

