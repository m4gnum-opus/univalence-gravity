-- ═══════════════════════════════════════════════════════════
--  Canonical views (dummy instances)
-- ═══════════════════════════════════════════════════════════

d50BdyView : D50BdyView
d50BdyView .D50BdyView.dummy = 0

d50BulkView : D50BulkView
d50BulkView .D50BulkView.dummy = 0

-- ═══════════════════════════════════════════════════════════
--  Observable packages for the Dense-50 {4,3,5} patch
-- ═══════════════════════════════════════════════════════════

D50Obs∂ : ObsPackage D50Region
D50Obs∂ .ObsPackage.obs = S-cut d50BdyView

D50ObsBulk : ObsPackage D50Region
D50ObsBulk .ObsPackage.obs = L-min d50BulkView

