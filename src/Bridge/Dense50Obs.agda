-- ═══════════════════════════════════════════════════════════
--  d50-obs-path — Function equality via funExt
-- ═══════════════════════════════════════════════════════════
--
--  Packages the 139 pointwise refl proofs into a single path
--  between the boundary and bulk observable functions:
--    S∂D50 ≡ LBD50
--
--  This is the 3D analogue of star-obs-path and
--  filled-obs-path, now on a densely-connected 3D patch
--  with non-trivial separating-surface geometry.
--

S∂D50 : D50Region → ℚ≥0
S∂D50 = S-cut d50BdyView

LBD50 : D50Region → ℚ≥0
LBD50 = L-min d50BulkView

d50-obs-path : S∂D50 ≡ LBD50
d50-obs-path = funExt d50-pointwise

-- ═══════════════════════════════════════════════════════════
--  d50-package-path — Package-level path
-- ═══════════════════════════════════════════════════════════
--
--  Identifies the boundary and bulk observable packages.
--  The downstream enriched equivalence (Dense50Equiv.agda)
--  uses d50-obs-path to construct the Iso / Equiv / ua /
--  transport pipeline, mirroring Honeycomb3DEquiv.agda and
--  FilledEquiv.agda.
--

d50-package-path : D50Obs∂ ≡ D50ObsBulk
d50-package-path i .ObsPackage.obs = d50-obs-path i

