module Bridge.Layer54d4Obs where

open import Cubical.Foundations.Prelude
open import Util.Scalars
open import Common.Layer54d4Spec
open import Common.ObsPackage
open import Boundary.Layer54d4Cut
open import Bulk.Layer54d4Chain

layer54d4BdyView : Layer54d4BdyView
layer54d4BdyView .Layer54d4BdyView.dummy = 0

layer54d4BulkView : Layer54d4BulkView
layer54d4BulkView .Layer54d4BulkView.dummy = 0

Layer54d4Obs∂ : ObsPackage Layer54d4Region
Layer54d4Obs∂ .ObsPackage.obs = S-cut layer54d4BdyView

Layer54d4ObsBulk : ObsPackage Layer54d4Region
Layer54d4ObsBulk .ObsPackage.obs = L-min layer54d4BulkView

-- layer54d4-pointwise-rep — All 2 orbit cases by refl
-- S-cut-rep and L-min-rep return the same ℕ literal on each orbit.
--  Generated by sim/prototyping/13_generate_layerN.py --depth 4
--  Do not edit by hand.  Regenerate with:
--    python3 sim/prototyping/13_generate_layerN.py --depth 4

layer54d4-pointwise-rep :
  (o : Layer54d4OrbitRep) → S-cut-rep o ≡ L-min-rep o
layer54d4-pointwise-rep mc1 = refl
layer54d4-pointwise-rep mc2 = refl

-- layer54d4-pointwise — Lifted to all 105 regions
-- via classifyLayer54d4 (the orbit reduction 1-line lifting)
--  Generated by sim/prototyping/13_generate_layerN.py --depth 4
--  Do not edit by hand.  Regenerate with:
--    python3 sim/prototyping/13_generate_layerN.py --depth 4

layer54d4-pointwise :
  (r : Layer54d4Region) →
  S-cut layer54d4BdyView r ≡ L-min layer54d4BulkView r
layer54d4-pointwise r = layer54d4-pointwise-rep (classifyLayer54d4 r)

S∂Layer54d4 : Layer54d4Region → ℚ≥0
S∂Layer54d4 = S-cut layer54d4BdyView

LBLayer54d4 : Layer54d4Region → ℚ≥0
LBLayer54d4 = L-min layer54d4BulkView

layer54d4-obs-path : S∂Layer54d4 ≡ LBLayer54d4
layer54d4-obs-path = funExt layer54d4-pointwise

layer54d4-package-path : Layer54d4Obs∂ ≡ Layer54d4ObsBulk
layer54d4-package-path i .ObsPackage.obs = layer54d4-obs-path i

