layer54d7BdyView : Layer54d7BdyView
layer54d7BdyView .Layer54d7BdyView.dummy = 0

layer54d7BulkView : Layer54d7BulkView
layer54d7BulkView .Layer54d7BulkView.dummy = 0

Layer54d7Obs∂ : ObsPackage Layer54d7Region
Layer54d7Obs∂ .ObsPackage.obs = S-cut layer54d7BdyView

Layer54d7ObsBulk : ObsPackage Layer54d7Region
Layer54d7ObsBulk .ObsPackage.obs = L-min layer54d7BulkView

-- layer54d7-pointwise-rep — All 2 orbit cases by refl
-- S-cut-rep and L-min-rep return the same ℕ literal on each orbit.
--  Generated by sim/prototyping/13_generate_layerN.py --depth 7
--  Do not edit by hand.  Regenerate with:
--    python3 sim/prototyping/13_generate_layerN.py --depth 7

layer54d7-pointwise-rep :
  (o : Layer54d7OrbitRep) → S-cut-rep o ≡ L-min-rep o
layer54d7-pointwise-rep mc1 = refl
layer54d7-pointwise-rep mc2 = refl

-- layer54d7-pointwise — Lifted to all 1885 regions
-- via classifyLayer54d7 (the orbit reduction 1-line lifting)
--  Generated by sim/prototyping/13_generate_layerN.py --depth 7
--  Do not edit by hand.  Regenerate with:
--    python3 sim/prototyping/13_generate_layerN.py --depth 7

layer54d7-pointwise :
  (r : Layer54d7Region) →
  S-cut layer54d7BdyView r ≡ L-min layer54d7BulkView r
layer54d7-pointwise r = layer54d7-pointwise-rep (classifyLayer54d7 r)

S∂Layer54d7 : Layer54d7Region → ℚ≥0
S∂Layer54d7 = S-cut layer54d7BdyView

LBLayer54d7 : Layer54d7Region → ℚ≥0
LBLayer54d7 = L-min layer54d7BulkView

layer54d7-obs-path : S∂Layer54d7 ≡ LBLayer54d7
layer54d7-obs-path = funExt layer54d7-pointwise

layer54d7-package-path : Layer54d7Obs∂ ≡ Layer54d7ObsBulk
layer54d7-package-path i .ObsPackage.obs = layer54d7-obs-path i

