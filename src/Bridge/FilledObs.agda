-- ════════════════════════════════════════════════════════════
--  Canonical views (dummy instances)
-- ════════════════════════════════════════════════════════════

filledBdyView : FilledBdyView
filledBdyView .FilledBdyView.dummy = 0

filledBulkView : FilledBulkView
filledBulkView .FilledBulkView.dummy = 0

-- ════════════════════════════════════════════════════════════
--  Observable packages for the 11-tile filled patch
-- ════════════════════════════════════════════════════════════

FilledObs∂ : ObsPackage FilledRegion
FilledObs∂ .ObsPackage.obs = S-cut filledBdyView

FilledObsBulk : ObsPackage FilledRegion
FilledObsBulk .ObsPackage.obs = L-min filledBulkView

