-- ═══════════════════════════════════════════════════════════
--  h3-obs-path — Function equality via funExt
-- ═══════════════════════════════════════════════════════════

h3-obs-path :
  S-cut h3BdyView ≡ L-min h3BulkView
h3-obs-path = funExt h3-pointwise

-- ═══════════════════════════════════════════════════════════
--  h3-package-path — Package-level path
-- ═══════════════════════════════════════════════════════════
--
--  This is the 3D analogue of filled-package-path: it
--  identifies the boundary and bulk observable packages
--  for the {4,3,5} honeycomb patch.  The downstream
--  enriched equivalence (Phase D.3) mirrors FilledEquiv.agda
--  using h3-obs-path in place of filled-obs-path.
--

h3-package-path : H3Obs∂ ≡ H3ObsBulk
h3-package-path i .ObsPackage.obs = h3-obs-path i

