-- ═══════════════════════════════════════════════════════════
--  Canonical views (dummy instances)
-- ═══════════════════════════════════════════════════════════

h3BdyView : H3BdyView
h3BdyView .H3BdyView.dummy = 0

h3BulkView : H3BulkView
h3BulkView .H3BulkView.dummy = 0

-- ═══════════════════════════════════════════════════════════
--  Observable packages for the 3D {4,3,5} patch
-- ═══════════════════════════════════════════════════════════

H3Obs∂ : ObsPackage H3Region
H3Obs∂ .ObsPackage.obs = S-cut h3BdyView

H3ObsBulk : ObsPackage H3Region
H3ObsBulk .ObsPackage.obs = L-min h3BulkView

