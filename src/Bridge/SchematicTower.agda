  check-dense-monotone : LayerStep.monotone d100→d200 ≡ (1 , refl)
  check-dense-monotone = refl

  -- ── {5,4} flat monotonicity witness ──────────────────────────
  check-54-monotone : LayerStep.monotone step-d2→d3 ≡ (0 , refl)
