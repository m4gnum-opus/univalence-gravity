  -- ── Dense maxCut values ──────────────────────────────────────
  check-d100-maxCut : TowerLevel.maxCut d100-tower-level ≡ 8
  check-d100-maxCut = refl

  check-d200-maxCut : TowerLevel.maxCut d200-tower-level ≡ 9
