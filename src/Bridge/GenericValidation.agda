-- ════════════════════════════════════════════════════════════════════
--  §1.  Star Instance  (10 regions, 2D {5,4} star patch)
-- ════════════════════════════════════════════════════════════════════
--
--  The 6-tile star patch is the simplest nontrivial bridge instance.
--  Both S∂ and LB are 10-clause lookup tables returning 1q or 2q,
--  and star-obs-path is funExt of 10 refl proofs.
--
--  Existing modules:
--    Common/StarSpec.agda           — Region (10 constructors)
--    Bridge/EnrichedStarObs.agda    — S∂, LB, enriched-equiv
--    Bridge/StarEquiv.agda          — star-obs-path
--    Bridge/EnrichedStarEquiv.agda  — spec-witness : BridgeWitness
--
--  Validation: the generic GenericEnriched applied to starPatchData
--  produces a BridgeWitness that type-checks.
-- ════════════════════════════════════════════════════════════════════

open import Common.StarSpec using (Region)
open import Bridge.EnrichedStarObs
  using ()
  renaming (S∂ to star-S∂ ; LB to star-LB)
open import Bridge.StarEquiv using (star-obs-path)

starPatchData : PatchData
starPatchData .PatchData.RegionTy = Region
starPatchData .PatchData.S∂       = star-S∂
starPatchData .PatchData.LB       = star-LB
starPatchData .PatchData.obs-path = star-obs-path

module StarGeneric = GenericEnriched starPatchData

star-generic-witness : BridgeWitness
star-generic-witness = StarGeneric.abstract-bridge-witness

-- ── Coherence: PatchData fields are the concrete imports ────────
private
  star-S∂-check : PatchData.S∂ starPatchData ≡ star-S∂
  star-S∂-check = refl

  star-LB-check : PatchData.LB starPatchData ≡ star-LB
  star-LB-check = refl


