--  §9.  Summary and Design Notes
-- ════════════════════════════════════════════════════════════════════
--
--  Exports:
--
--    starPatchData        : PatchData
--    filledPatchData      : PatchData
--    h3PatchData          : PatchData
--    d50PatchData         : PatchData
--    d100OrbitPatch       : OrbitReducedPatch
--    d200OrbitPatch       : OrbitReducedPatch
