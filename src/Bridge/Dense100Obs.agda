-- ═══════════════════════════════════════════════════════════
--  Canonical views (dummy instances)
-- ═══════════════════════════════════════════════════════════

d100BdyView : D100BdyView
d100BdyView .D100BdyView.dummy = 0

d100BulkView : D100BulkView
d100BulkView .D100BulkView.dummy = 0

-- ═══════════════════════════════════════════════════════════
--  Observable packages for the Dense-100 {4,3,5} patch
-- ═══════════════════════════════════════════════════════════

D100Obs∂ : ObsPackage D100Region
D100Obs∂ .ObsPackage.obs = S-cut d100BdyView

D100ObsBulk : ObsPackage D100Region
D100ObsBulk .ObsPackage.obs = L-min d100BulkView

-- ═══════════════════════════════════════════════════════════
--  d100-pointwise-rep — All 8 orbit cases by refl
-- ═══════════════════════════════════════════════════════════
--
--  The core proof: S-cut-rep and L-min-rep agree on every
--  orbit representative.  Both return the same ℕ literal
--  for each orbit (the shared min-cut value), so each case
--  holds by refl.
--
--  This replaces the 717-case pointwise proof from the flat
--  enumeration approach (Dense-50 style) with a compact
--  8-case proof on orbit representatives.
--
--  Generated by sim/prototyping/09_generate_dense100.py
--  Do not edit by hand.  Regenerate with:
--    python3 sim/prototyping/09_generate_dense100.py

d100-pointwise-rep :
  (o : D100OrbitRep) → S-cut-rep o ≡ L-min-rep o
d100-pointwise-rep mc1 = refl
d100-pointwise-rep mc2 = refl
d100-pointwise-rep mc3 = refl
d100-pointwise-rep mc4 = refl
d100-pointwise-rep mc5 = refl
d100-pointwise-rep mc6 = refl
d100-pointwise-rep mc7 = refl
d100-pointwise-rep mc8 = refl

-- ═══════════════════════════════════════════════════════════
--  d100-pointwise — Lifted to all 717 regions
-- ═══════════════════════════════════════════════════════════
--
--  The pointwise agreement for the full D100Region type is a
--  SINGLE-LINE proof that composes the orbit-level proof with
--  the classification function:
--
--    d100-pointwise r = d100-pointwise-rep (classify100 r)
--
--  This works because:
--    S-cut _ r  = S-cut-rep (classify100 r)    (definitional)
--    L-min _ r  = L-min-rep (classify100 r)    (definitional)
--
--  So the type of  d100-pointwise-rep (classify100 r)  is:
--    S-cut-rep (classify100 r) ≡ L-min-rep (classify100 r)
--  which IS  S-cut _ r ≡ L-min _ r  by the definitional
--  equalities above.
--
--  For a concrete constructor r, Agda normalizes classify100 r
--  (one step on the 717-clause function), then
--  d100-pointwise-rep on the result (one step on the
--  8-clause function, returning refl).  Fast.
--
--  This is the orbit reduction strategy from §6.5 of
--  docs/10-frontier.md in action: the proof term is tiny,
--  the classification function does the case analysis.
--
--  Generated by sim/prototyping/09_generate_dense100.py
--  Do not edit by hand.  Regenerate with:
--    python3 sim/prototyping/09_generate_dense100.py

d100-pointwise :
  (r : D100Region) →
  S-cut d100BdyView r ≡ L-min d100BulkView r
d100-pointwise r = d100-pointwise-rep (classify100 r)

-- ═══════════════════════════════════════════════════════════
--  d100-obs-path — Function equality via funExt
-- ═══════════════════════════════════════════════════════════

S∂D100 : D100Region → ℚ≥0
S∂D100 = S-cut d100BdyView

LBD100 : D100Region → ℚ≥0
LBD100 = L-min d100BulkView

d100-obs-path : S∂D100 ≡ LBD100
d100-obs-path = funExt d100-pointwise

-- ═══════════════════════════════════════════════════════════
--  d100-package-path — Package-level path
-- ═══════════════════════════════════════════════════════════

d100-package-path : D100Obs∂ ≡ D100ObsBulk
d100-package-path i .ObsPackage.obs = d100-obs-path i

