d200-pointwise :
  (r : D200Region) →
  S-cut d200BdyView r ≡ L-min d200BulkView r
d200-pointwise r = d200-pointwise-rep (classify200 r)

S∂D200 : D200Region → ℚ≥0
S∂D200 = S-cut d200BdyView

LBD200 : D200Region → ℚ≥0
LBD200 = L-min d200BulkView

d200-obs-path : S∂D200 ≡ LBD200
d200-obs-path = funExt d200-pointwise

d200-package-path : D200Obs∂ ≡ D200ObsBulk
d200-package-path i .ObsPackage.obs = d200-obs-path i

