module Bridge.Layer54d5Obs where

open import Cubical.Foundations.Prelude
open import Util.Scalars
open import Common.Layer54d5Spec
open import Common.ObsPackage
open import Boundary.Layer54d5Cut
open import Bulk.Layer54d5Chain

layer54d5BdyView : Layer54d5BdyView
layer54d5BdyView .Layer54d5BdyView.dummy = 0

layer54d5BulkView : Layer54d5BulkView
layer54d5BulkView .Layer54d5BulkView.dummy = 0

Layer54d5Obs∂ : ObsPackage Layer54d5Region
Layer54d5Obs∂ .ObsPackage.obs = S-cut layer54d5BdyView

Layer54d5ObsBulk : ObsPackage Layer54d5Region
Layer54d5ObsBulk .ObsPackage.obs = L-min layer54d5BulkView

-- layer54d5-pointwise-rep — All 2 orbit cases by refl
-- S-cut-rep and L-min-rep return the same ℕ literal on each orbit.
--  Generated by sim/prototyping/13_generate_layerN.py --depth 5
--  Do not edit by hand.  Regenerate with:
--    python3 sim/prototyping/13_generate_layerN.py --depth 5

layer54d5-pointwise-rep :
  (o : Layer54d5OrbitRep) → S-cut-rep o ≡ L-min-rep o
layer54d5-pointwise-rep mc1 = refl
layer54d5-pointwise-rep mc2 = refl

-- layer54d5-pointwise — Lifted to all 275 regions
-- via classifyLayer54d5 (the orbit reduction 1-line lifting)
--  Generated by sim/prototyping/13_generate_layerN.py --depth 5
--  Do not edit by hand.  Regenerate with:
--    python3 sim/prototyping/13_generate_layerN.py --depth 5

layer54d5-pointwise :
  (r : Layer54d5Region) →
  S-cut layer54d5BdyView r ≡ L-min layer54d5BulkView r
layer54d5-pointwise r = layer54d5-pointwise-rep (classifyLayer54d5 r)

S∂Layer54d5 : Layer54d5Region → ℚ≥0
S∂Layer54d5 = S-cut layer54d5BdyView

LBLayer54d5 : Layer54d5Region → ℚ≥0
LBLayer54d5 = L-min layer54d5BulkView

layer54d5-obs-path : S∂Layer54d5 ≡ LBLayer54d5
layer54d5-obs-path = funExt layer54d5-pointwise

layer54d5-package-path : Layer54d5Obs∂ ≡ Layer54d5ObsBulk
layer54d5-package-path i .ObsPackage.obs = layer54d5-obs-path i

