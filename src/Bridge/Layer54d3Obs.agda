{-# OPTIONS --cubical --safe --guardedness #-}

module Bridge.Layer54d3Obs where

open import Cubical.Foundations.Prelude
open import Util.Scalars
open import Common.Layer54d3Spec
open import Common.ObsPackage
open import Boundary.Layer54d3Cut
open import Bulk.Layer54d3Chain

layer54d3BdyView : Layer54d3BdyView
layer54d3BdyView .Layer54d3BdyView.dummy = 0

layer54d3BulkView : Layer54d3BulkView
layer54d3BulkView .Layer54d3BulkView.dummy = 0

Layer54d3Obs∂ : ObsPackage Layer54d3Region
Layer54d3Obs∂ .ObsPackage.obs = S-cut layer54d3BdyView

Layer54d3ObsBulk : ObsPackage Layer54d3Region
Layer54d3ObsBulk .ObsPackage.obs = L-min layer54d3BulkView

-- layer54d3-pointwise-rep — All 2 orbit cases by refl
-- S-cut-rep and L-min-rep return the same ℕ literal on each orbit.
--  Generated by sim/prototyping/13_generate_layerN.py --depth 3
--  Do not edit by hand.  Regenerate with:
--    python3 sim/prototyping/13_generate_layerN.py --depth 3

layer54d3-pointwise-rep :
  (o : Layer54d3OrbitRep) → S-cut-rep o ≡ L-min-rep o
layer54d3-pointwise-rep mc1 = refl
layer54d3-pointwise-rep mc2 = refl

-- layer54d3-pointwise — Lifted to all 40 regions
-- via classifyLayer54d3 (the orbit reduction 1-line lifting)
--  Generated by sim/prototyping/13_generate_layerN.py --depth 3
--  Do not edit by hand.  Regenerate with:
--    python3 sim/prototyping/13_generate_layerN.py --depth 3

layer54d3-pointwise :
  (r : Layer54d3Region) →
  S-cut layer54d3BdyView r ≡ L-min layer54d3BulkView r
layer54d3-pointwise r = layer54d3-pointwise-rep (classifyLayer54d3 r)

S∂Layer54d3 : Layer54d3Region → ℚ≥0
S∂Layer54d3 = S-cut layer54d3BdyView

LBLayer54d3 : Layer54d3Region → ℚ≥0
LBLayer54d3 = L-min layer54d3BulkView

layer54d3-obs-path : S∂Layer54d3 ≡ LBLayer54d3
layer54d3-obs-path = funExt layer54d3-pointwise

layer54d3-package-path : Layer54d3Obs∂ ≡ Layer54d3ObsBulk
layer54d3-package-path i .ObsPackage.obs = layer54d3-obs-path i

