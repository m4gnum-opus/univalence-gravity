private
  isContrRevSingl : ∀ {ℓ} {A : Type ℓ} (a : A)
    → isContr (Σ[ x ∈ A ] (x ≡ a))
  isContrRevSingl a .fst = a , refl
  isContrRevSingl a .snd (x , p) i =
    p (~ i) , λ j → p (~ i ∨ j)

isContr-RawBdy : isContr RawFilledBdy
isContr-RawBdy = isContrRevSingl S∂F

isContr-RawBulk : isContr RawFilledBulk
isContr-RawBulk = isContrRevSingl filledWeight

-- ═══════════════════════════════════════════════════════════
--  §13.  The Iso between raw types
-- ═══════════════════════════════════════════════════════════

raw-filled-iso : Iso RawFilledBulk RawFilledBdy
raw-filled-iso = iso fwd bwd fwd-bwd bwd-fwd
  where
    fwd : RawFilledBulk → RawFilledBdy
    fwd (w , p) = minCutFromWeights w , cong minCutFromWeights p ∙ rt-lemma

    bwd : RawFilledBdy → RawFilledBulk
    bwd (f , q) = weightsFromMinCut f , cong weightsFromMinCut q ∙ extr-lemma

    fwd-bwd : (b : RawFilledBdy) → fwd (bwd b) ≡ b
    fwd-bwd b = isContr→isProp isContr-RawBdy (fwd (bwd b)) b

    bwd-fwd : (a : RawFilledBulk) → bwd (fwd a) ≡ a
    bwd-fwd a = isContr→isProp isContr-RawBulk (bwd (fwd a)) a

-- ═══════════════════════════════════════════════════════════
--  §14.  Equivalence, Univalence path, and transport
-- ═══════════════════════════════════════════════════════════

raw-filled-equiv : RawFilledBulk ≃ RawFilledBdy
raw-filled-equiv = isoToEquiv raw-filled-iso

raw-filled-ua-path : RawFilledBulk ≡ RawFilledBdy
raw-filled-ua-path = ua raw-filled-equiv

raw-filled-transport-computes :
  transport raw-filled-ua-path raw-filled-bulk
  ≡ equivFun raw-filled-equiv raw-filled-bulk
raw-filled-transport-computes = uaβ raw-filled-equiv raw-filled-bulk

private
  raw-fwd-eq-bdy : equivFun raw-filled-equiv raw-filled-bulk ≡ raw-filled-bdy
  raw-fwd-eq-bdy = isContr→isProp isContr-RawBdy _ _

raw-filled-transport :
  transport raw-filled-ua-path raw-filled-bulk ≡ raw-filled-bdy
raw-filled-transport = raw-filled-transport-computes ∙ raw-fwd-eq-bdy

raw-filled-transport-obs :
  fst (transport raw-filled-ua-path raw-filled-bulk) ≡ S∂F
raw-filled-transport-obs = cong fst raw-filled-transport

-- ═══════════════════════════════════════════════════════════
--  §15.  Reverse transport and roundtrip
-- ═══════════════════════════════════════════════════════════

raw-filled-reverse :
  transport (sym raw-filled-ua-path) raw-filled-bdy ≡ raw-filled-bulk
raw-filled-reverse =
    cong (transport (sym raw-filled-ua-path)) (sym raw-filled-transport)
  ∙ transport⁻Transport raw-filled-ua-path raw-filled-bulk

raw-filled-roundtrip-bulk :
  transport (sym raw-filled-ua-path)
    (transport raw-filled-ua-path raw-filled-bulk)
  ≡ raw-filled-bulk
raw-filled-roundtrip-bulk = transport⁻Transport raw-filled-ua-path raw-filled-bulk

raw-filled-roundtrip-bdy :
  transport raw-filled-ua-path
    (transport (sym raw-filled-ua-path) raw-filled-bdy)
  ≡ raw-filled-bdy
raw-filled-roundtrip-bdy = transportTransport⁻ raw-filled-ua-path raw-filled-bdy

-- ═══════════════════════════════════════════════════════════
--  §16.  RawFilledBridgeWitness
-- ═══════════════════════════════════════════════════════════

record RawFilledBridgeWitness : Type₁ where
  field
    BulkTy             : Type₀
    BdyTy              : Type₀
    bulk-data          : BulkTy
    bdy-data           : BdyTy
    bridge             : BulkTy ≃ BdyTy
    transport-verified : transport (ua bridge) bulk-data ≡ bdy-data

raw-filled-bridge-witness : RawFilledBridgeWitness
raw-filled-bridge-witness .RawFilledBridgeWitness.BulkTy             = RawFilledBulk
raw-filled-bridge-witness .RawFilledBridgeWitness.BdyTy              = RawFilledBdy
raw-filled-bridge-witness .RawFilledBridgeWitness.bulk-data          = raw-filled-bulk
raw-filled-bridge-witness .RawFilledBridgeWitness.bdy-data           = raw-filled-bdy
raw-filled-bridge-witness .RawFilledBridgeWitness.bridge             = raw-filled-equiv
raw-filled-bridge-witness .RawFilledBridgeWitness.transport-verified = raw-filled-transport

-- ═══════════════════════════════════════════════════════════
--  §17.  Compatibility with observable-level bridge
-- ═══════════════════════════════════════════════════════════
--
--  The raw transport's extracted function S∂F is the same
--  function used in Bridge/FilledEquiv.agda, so the raw
--  structural equivalence is compatible with the enriched
--  observable-package equivalence.
--

raw-filled-obs-coherence :
  fst (transport raw-filled-ua-path raw-filled-bulk) ≡ S∂F
raw-filled-obs-coherence = raw-filled-transport-obs

raw-filled-bulk-coherence :
  fst (transport raw-filled-ua-path raw-filled-bulk) ≡ LBF
raw-filled-bulk-coherence = raw-filled-transport-obs ∙ filled-obs-path

