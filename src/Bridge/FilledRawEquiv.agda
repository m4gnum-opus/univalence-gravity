-- ═══════════════════════════════════════════════════════════
--  §1.  Truncated subtraction (monus)
-- ═══════════════════════════════════════════════════════════
--
--  Defined locally to guarantee judgmental computation.
--  suc (suc (suc zero)) ∸ suc (suc zero)  reduces to
--  suc zero  by structural recursion.  This is critical
--  for the 15 refl proofs in the extraction lemma.
--

private
  _∸_ : ℕ → ℕ → ℕ
  zero  ∸ _     = zero
  suc m ∸ zero  = suc m
  suc m ∸ suc n = m ∸ n

-- ═══════════════════════════════════════════════════════════
--  §2.  FilledBond — 15 internal tile-to-tile bonds
-- ═══════════════════════════════════════════════════════════
--
--  5 C-bonds:  C–N_i           (central to neighbours)
-- 10 G-bonds:  G_i–N_{i−1},  G_i–N_i  (gap-fillers)
--

data FilledBond : Type₀ where
  bCN0 bCN1 bCN2 bCN3 bCN4 : FilledBond
  bG0N4 bG0N0 : FilledBond
  bG1N0 bG1N1 : FilledBond
  bG2N1 bG2N2 : FilledBond
  bG3N2 bG3N3 : FilledBond
  bG4N3 bG4N4 : FilledBond

-- ═══════════════════════════════════════════════════════════
--  §3.  Canonical weight function (all bonds weight 1)
-- ═══════════════════════════════════════════════════════════

filledWeight : FilledBond → ℚ≥0
filledWeight _ = 1

-- ═══════════════════════════════════════════════════════════
--  §4.  Shorthand names for canonical observables
-- ═══════════════════════════════════════════════════════════

S∂F : FilledRegion → ℚ≥0
S∂F = S-cut filledBdyView

LBF : FilledRegion → ℚ≥0
LBF = L-min filledBulkView

-- ═══════════════════════════════════════════════════════════
--  §5.  h-Level infrastructure
-- ═══════════════════════════════════════════════════════════

isSetRegionObs : isSet (FilledRegion → ℚ≥0)
isSetRegionObs = isOfHLevelΠ 2 (λ _ → isSetℚ≥0)

isSetBondW : isSet (FilledBond → ℚ≥0)
isSetBondW = isOfHLevelΠ 2 (λ _ → isSetℚ≥0)

-- ═══════════════════════════════════════════════════════════
--  §6.  Raw structural types
-- ═══════════════════════════════════════════════════════════

RawFilledBdy : Type₀
RawFilledBdy = Σ[ f ∈ (FilledRegion → ℚ≥0) ] (f ≡ S∂F)

RawFilledBulk : Type₀
RawFilledBulk = Σ[ w ∈ (FilledBond → ℚ≥0) ] (w ≡ filledWeight)

-- ═══════════════════════════════════════════════════════════
--  §7.  Canonical inhabitants
-- ═══════════════════════════════════════════════════════════

raw-filled-bdy : RawFilledBdy
raw-filled-bdy = S∂F , refl

raw-filled-bulk : RawFilledBulk
raw-filled-bulk = filledWeight , refl

