--  §9.  Backward map — Holographic reconstruction
-- ═══════════════════════════════════════════════════════════
--
--  Recover each bond weight from min-cut values.
--  G-bonds:  f(G_i singleton) ∸ 1  =  2 ∸ 1  =  1
--  C-bonds:  f(N_i,G_{i+1} pair) ∸ f(G_{i+1} singleton)
--           =  3 ∸ 2  =  1
--
--  Generated by sim/prototyping/04_generate_raw_equiv.py
--  Do not edit by hand.  Regenerate with:
--    python3 sim/prototyping/04_generate_raw_equiv.py

weightsFromMinCut : (FilledRegion → ℚ≥0) → (FilledBond → ℚ≥0)
weightsFromMinCut f bCN0 = f r0x2 ∸ f r1x1    -- S({N0,G1}) ∸ S({G1}) = 3 ∸ 2 = 1
