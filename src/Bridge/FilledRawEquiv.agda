weightsFromMinCut f bG4N3 = f r7x1 ∸ 1    -- S({G4}) ∸ 1 = 2 ∸ 1 = 1
weightsFromMinCut f bG4N4 = f r7x1 ∸ 1    -- S({G4}) ∸ 1 = 2 ∸ 1 = 1

