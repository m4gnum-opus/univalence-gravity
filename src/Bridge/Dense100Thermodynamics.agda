-- ════════════════════════════════════════════════════════════════════
--  §1.  Type Compatibility Verification
-- ════════════════════════════════════════════════════════════════════
--
--  Before constructing the triple, we verify that all types align:
--
--    CoarseGrainWitness.FineRegion dense100-coarse-witness
--      = D100Region                              (definitional)
--
--    CoarseGrainWitness.obs-fine dense100-coarse-witness
--      = S-cut d100BdyView                       (definitional)
--
--  Therefore:
--    • regionArea : D100Region → ℚ≥0
--      has the type expected by the second Sigma component:
--        CoarseGrainWitness.FineRegion dense100-coarse-witness → ℚ≥0
--
--    • area-law : (r : D100Region) → S-cut d100BdyView r ≤ℚ regionArea r
--      has the type expected by the third Sigma component:
--        (r : CoarseGrainWitness.FineRegion w) →
--        CoarseGrainWitness.obs-fine w r ≤ℚ regionArea r
--
--  These equalities hold definitionally, so no coercion is needed.
-- ════════════════════════════════════════════════════════════════════

private
  -- FineRegion of the witness is D100Region
  fine-region-check :
    CoarseGrainWitness.FineRegion dense100-coarse-witness ≡ D100Region
  fine-region-check = refl

  -- obs-fine of the witness is S-cut d100BdyView
  obs-fine-check :
    CoarseGrainWitness.obs-fine dense100-coarse-witness ≡ S-cut d100BdyView
  obs-fine-check = refl


-- ════════════════════════════════════════════════════════════════════
--  §2.  The CoarseGrainedRT Instance
-- ════════════════════════════════════════════════════════════════════
--
--  The fully formalized statement from §8.10 of docs/10-frontier.md:
--
--    CoarseGrainedRT = Σ[ w ∈ CoarseGrainWitness ]
--      Σ[ regionArea ∈ (FineRegion w → ℚ≥0) ]
--        ((r : FineRegion w) → obs-fine w r ≤ℚ regionArea r)
--
--  The triple (dense100-coarse-witness , regionArea , area-law)
--  instantiates this type because:
--
--    w           = dense100-coarse-witness
--    regionArea  : FineRegion w → ℚ≥0
--                = D100Region → ℚ≥0             (definitional)
--    area-law    : (r : FineRegion w) → obs-fine w r ≤ℚ regionArea r
--                = (r : D100Region) → S-cut d100BdyView r ≤ℚ regionArea r
--                                                        (definitional)
--
--  The area-law field is abstract (sealed in Dense100AreaLaw.agda),
--  so downstream modules never re-unfold the 717 case analyses.
--  Since _≤ℚ_ is propositional (by isProp≤ℚ from
--  Bridge/FullEnrichedStarObs.agda), the abstract barrier does not
--  damage any Univalence bridge or transport computation.
-- ════════════════════════════════════════════════════════════════════

dense100-thermodynamics : CoarseGrainedRT
dense100-thermodynamics = dense100-coarse-witness , regionArea , area-law


-- ════════════════════════════════════════════════════════════════════
--  §3.  Component Extraction
-- ════════════════════════════════════════════════════════════════════
--
--  The three components of the triple are extractable as projections.
--  These serve as stable references for downstream modules and
--  documentation.
-- ════════════════════════════════════════════════════════════════════

-- The coarse-graining witness (orbit reduction 717 → 8)
the-witness : CoarseGrainWitness
the-witness = fst dense100-thermodynamics

-- The boundary area function
the-area : D100Region → ℚ≥0
the-area = fst (snd dense100-thermodynamics)

-- The area-law bound (abstract)
the-bound : (r : D100Region)
  → CoarseGrainWitness.obs-fine the-witness r ≤ℚ the-area r
the-bound = snd (snd dense100-thermodynamics)


