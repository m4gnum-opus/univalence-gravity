--  §1.  Type Compatibility Verification
-- ════════════════════════════════════════════════════════════════════
--
--  Before constructing the triple, we verify that all types align:
--
--    CoarseGrainWitness.FineRegion dense100-coarse-witness
--      = D100Region                              (definitional)
--
--    CoarseGrainWitness.obs-fine dense100-coarse-witness
--      = S-cut d100BdyView                       (definitional)
--
--  Therefore:
--    • regionArea : D100Region → ℚ≥0
--      has the type expected by the second Sigma component:
--        CoarseGrainWitness.FineRegion dense100-coarse-witness → ℚ≥0
--
--    • area-law : (r : D100Region) → S-cut d100BdyView r ≤ℚ regionArea r
--      has the type expected by the third Sigma component:
--        (r : CoarseGrainWitness.FineRegion w) →
--        CoarseGrainWitness.obs-fine w r ≤ℚ regionArea r
--
--  These equalities hold definitionally, so no coercion is needed.
-- ════════════════════════════════════════════════════════════════════

private
  -- FineRegion of the witness is D100Region
