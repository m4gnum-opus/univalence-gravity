-- ═══════════════════════════════════════════════════════════
--  L-min-rep — Bulk minimal surface on orbit representatives
-- ═══════════════════════════════════════════════════════════
--
--  8-clause lookup on the small orbit type.
--  Each orbit representative maps to the same min-cut value
--  as S-cut-rep — this is the 3D discrete RT correspondence.
--
--  Generated by sim/prototyping/09_generate_dense100.py
--  Do not edit by hand.  Regenerate with:
--    python3 sim/prototyping/09_generate_dense100.py

L-min-rep : D100OrbitRep → ℚ≥0
L-min-rep mc1 = 1
L-min-rep mc2 = 2
L-min-rep mc3 = 3
L-min-rep mc4 = 4
L-min-rep mc5 = 5
L-min-rep mc6 = 6
L-min-rep mc7 = 7
L-min-rep mc8 = 8

-- ═══════════════════════════════════════════════════════════
--  L-min — Bulk minimal separating surface for Dense-100
-- ═══════════════════════════════════════════════════════════
--
--  Defined as  L-min-rep ∘ classify100 , mirroring S-cut.
--  Both S-cut and L-min are definitionally distinct (defined
--  in different modules with different rep functions) but
--  propositionally equal because S-cut-rep and L-min-rep
--  agree on all 8 orbit representatives by refl.
--
--  Generated by sim/prototyping/09_generate_dense100.py
--  Do not edit by hand.  Regenerate with:
--    python3 sim/prototyping/09_generate_dense100.py

L-min : D100BulkView → D100Region → ℚ≥0
L-min _ r = L-min-rep (classify100 r)

