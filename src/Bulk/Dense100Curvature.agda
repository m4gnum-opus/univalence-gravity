-- ═══════════════════════════════════════════════════════════
--  3D Edge Curvature for the Dense-100 {4,3,5} Patch
-- ═══════════════════════════════════════════════════════════
--
--  In 3D, curvature lives on EDGES (not vertices).
--  At an interior edge e with valence v (cubes meeting):
--    κ(e) = 2π − v · (π/2)
--
--  For {4,3,5}: full valence = 5, so κ = −π/2 (hyperbolic).
--
--  Combinatorial encoding in twentieths (via ℚ₁₀ = ℤ):
--    κ₂₀(e) = 20 − 5·v
--      v=5 → κ₂₀ = −5   (hyperbolic)
--      v=4 → κ₂₀ =  0   (flat)
--      v=3 → κ₂₀ = +5   (boundary)
--      v=2 → κ₂₀ = +10  (boundary)
--
--  Generated by sim/prototyping/09_generate_dense100.py
--  Do not edit by hand.  Regenerate with:
--    python3 sim/prototyping/09_generate_dense100.py

-- ═══════════════════════════════════════════════════════════
--  D100EdgeClass — Edge classes by in-patch valence
-- ═══════════════════════════════════════════════════════════

data D100EdgeClass : Type₀ where
  ev5 : D100EdgeClass

d100EdgeCount : D100EdgeClass → ℕ
d100EdgeCount ev5 = 12

d100Valence : D100EdgeClass → ℕ
d100Valence ev5 = 5

-- Curvature in twentieths:  κ₂₀ = 20 − 5·valence
d100Kappa : D100EdgeClass → ℚ₁₀
d100Kappa ev5 = negsuc 4    -- val=5, κ₂₀=-5

-- ═══════════════════════════════════════════════════════════
