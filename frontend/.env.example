# Univalence Gravity — Frontend Environment Configuration
#
# Copy this file to `.env` (or `.env.local`) and adjust as needed.
# Vite exposes variables prefixed with VITE_ to client-side code
# via `import.meta.env`.
#
# See: https://vitejs.dev/guide/env-and-mode.html
#
# ─── Backend API Base URL ────────────────────────────────────────
#
# The Haskell backend REST API base URL (no trailing slash).
# All fetch() calls in src/api/client.ts are prefixed with this.
#
# Development default: the backend runs locally on port 8080.
# For production, set this to the deployed backend URL, e.g.:
#   VITE_API_URL=https://api.univalence-gravity.example.com
#
VITE_API_URL=http://localhost:8080